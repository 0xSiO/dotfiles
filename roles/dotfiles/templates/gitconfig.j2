    email = "6709262+0xSiO@users.noreply.github.com"
    signingkey = "B50141371B40B526"

[core]
    editor = vi --clean

[init]
    defaultBranch = master

{% if ansible_os_family == 'Darwin' %}
[url "git@github.com:"]
	insteadOf = https://github.com/

[credential]
    helper = osxkeychain

{% endif %}
[commit]
    gpgsign = true

[diff]
    algorithm = histogram

[pull]
    rebase = false

[pager]
    diff = delta
    show = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    features = side-by-side
    plus-style = syntax "#003800"
    wrap-max-lines = unlimited
